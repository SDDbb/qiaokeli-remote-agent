# OpenHands Tunnel Configuration
#
# Server bind address - 0.0.0.0 binds all interfaces
QIAOKELI_OH_TUNNEL_HOST=0.0.0.0
#
# Server port
QIAOKELI_OH_TUNNEL_PORT=8765
#
# Working directory where OpenHands should run
QIAOKELI_OH_TUNNEL_WORKDIR=~/桌面/openhands-playground
#
# OpenHands launch command
QIAOKELI_OH_TUNNEL_OPENHANDS_CMD=poetry run python -m openhands.core.main -c
#
# Maximum output buffer size (characters) for history
QIAOKELI_OH_TUNNEL_MAX_OUTPUT_BUFFER=200000
#
# WebSocket ping interval (seconds)
QIAOKELI_OH_TUNNEL_PING_INTERVAL=30
#
# Authentication token - leave empty for no auth (safe for private Tailscale net)
# Generate a random token for public access: python -c "import secrets; print(secrets.token_urlsafe(32))"
QIAOKELI_OH_TUNNEL_AUTH_TOKEN=
