# OpenHands Remote Tunnel Configuration

# Server bind address
# 0.0.0.0 allows any IP to connect (including USB and Tailscale)
BIND_HOST=0.0.0.0
BIND_PORT=8765

# Path to your OpenHands playground
OPENHANDS_WORKDIR=/home/zhujintao/桌面/openhands-playground

# Command to start OpenHands CLI
# Add cloned OpenHands repo to PYTHONPATH since it's not installed
OPENHANDS_CMD=export PYTHONPATH=/home/zhujintao/桌面/openhands:$PYTHONPATH && /home/zhujintao/桌面/openhands-playground/.venv/bin/python -m openhands.core.main -c

# Authentication token (generate a random string for security)
# Generate with: openssl rand -hex 16
AUTH_TOKEN=

# WebSocket ping interval in seconds
PING_INTERVAL=30

# Max output buffer size (default 1MB)
MAX_BUFFER_SIZE=1048576
