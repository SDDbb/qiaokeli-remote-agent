[Unit]
Description=Qiaokeli simple Syncthing remote agent
After=network-online.target syncthing.service openclaw-gateway.service
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=%h/桌面/qiaokeli-remote-agent
Environment=PYTHONUNBUFFERED=1
ExecStart=/usr/bin/python3 %h/桌面/qiaokeli-remote-agent/scripts/remote_agent_daemon.py
Restart=always
RestartSec=3

[Install]
WantedBy=default.target
