[Unit]
Description=Qiaokeli OpenHands Interactive Tunnel for Remote Vibe Coding
After=network.target tailscale.service

[Service]
Type=simple
ExecStart=/usr/bin/python3 %h/桌面/qiaokeli-remote-agent/scripts/openhands_tunnel_server.py
Restart=always
RestartSec=10
Environment=PYTHONUNBUFFERED=1

# Run in user context
User=%i

[Install]
WantedBy=default.target
